DJANGO_SECRET_KEY=change-this
JWT_SIGNING_KEY=replace-with-a-long-random-string-at-least-32-characters
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
RENDER=False
KOYEB=False

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional cookie/SSL overrides
# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True

# Point this to your Firebase service account JSON file
FIREBASE_CREDENTIALS=backend/firebase-service-account.json

# On Render, prefer using JSON directly instead of file path:
# FIREBASE_CREDENTIALS_JSON={...full firebase service account json...}

# Optional: switch to Postgres in production
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=your_db_name
# DB_USER=your_db_user
# DB_PASSWORD=your_db_password
# DB_HOST=your_db_host
# DB_PORT=5432

# If using Render Postgres, set DATABASE_URL instead of DB_* vars
# DATABASE_URL=postgres://...
