DJANGO_SECRET_KEY=change-this
JWT_SIGNING_KEY=replace-with-a-long-random-string-at-least-32-characters
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,ahju-backend.onrender.com
RENDER=False
KOYEB=False

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://bilta.com.ng,https://www.bilta.com.ng
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://bilta.com.ng,https://www.bilta.com.ng

# Optional cookie/SSL overrides
# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True

# Point this to your Firebase service account JSON file
FIREBASE_CREDENTIALS=backend/firebase-service-account.json

# On Render, prefer using JSON directly instead of file path:
# FIREBASE_CREDENTIALS_JSON={...full firebase service account json...}

# Optional: switch to Postgres in production
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=your_db_name
# DB_USER=your_db_user
# DB_PASSWORD=your_db_password
# DB_HOST=your_db_host
# DB_PORT=5432

# If using Render Postgres, set DATABASE_URL instead of DB_* vars
# DATABASE_URL=postgres://...

# Paystack
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxx
# Optional for testing against a mock gateway URL
# PAYSTACK_BASE_URL=https://api.paystack.co
# Optional frontend callback (Paystack redirect target)
PAYSTACK_CALLBACK_URL=http://localhost:5173/checkout/status

# Merchant notification email (gets full buyer + shipping details when payment succeeds)
PAYMENT_ORDER_NOTIFY_EMAIL=orders@myahju.com
# Multiple recipients (comma-separated). If set, this takes precedence.
PAYMENT_ORDER_NOTIFY_EMAILS=orders@myahju.com,ops@myahju.com

# SMTP config for sending notification emails
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
EMAIL_HOST_USER=your-gmail@gmail.com
EMAIL_HOST_PASSWORD=your-16-char-app-password-no-spaces
DEFAULT_FROM_EMAIL=your-gmail@gmail.com

# Supabase Storage (durable image uploads)
# SUPABASE_URL=https://your-project-ref.supabase.co
# SUPABASE_STORAGE_BUCKET=user-media
# SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
# Optional prefix inside bucket for all Django media files (e.g. media)
# SUPABASE_MEDIA_PREFIX=
# Optional for product seeding fallback image URLs:
# PRODUCT_IMAGE_FALLBACK_BASE_URL=https://raw.githubusercontent.com/TEESTIMONY/ahju/main








